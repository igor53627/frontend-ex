# frontend-ex route snippet for /mnt/sepolia/blockscout-proxy/Caddyfile on aya.
#
# Upstream:
# - frontend-ex release listens on 127.0.0.1:5174 (see ops/systemd/frontend-ex.env.example).
#
# Important:
# - frontend-ex enables `force_ssl` in production and relies on `X-Forwarded-Proto` from the edge.
# - Caddy's reverse_proxy sets `X-Forwarded-Proto` based on its own scheme (http), which can cause
#   HTTPS redirect loops behind Cloudflare.
# - Preserve the incoming header explicitly with:
#     header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
#
# Placement:
# - Put these handle blocks ABOVE any fast-frontend (Rust) fallback handles so they take precedence.
#

# ========== FRONTEND-EX ROUTES ==========

# Home page
handle / {
    reverse_proxy 127.0.0.1:5174 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
    }
    header Cache-Control "public, no-cache, no-store, must-revalidate"
    header X-Frontend "frontend-ex"
}

# Static assets (parity CSS/JS under /static/**)
handle /static/* {
    reverse_proxy 127.0.0.1:5174 {
        header_up Host {host}
        header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
    }
    header Cache-Control "public, max-age=31536000, immutable"
    header X-Frontend "frontend-ex"
}

# Export page (no upstream calls)
handle /exportData* {
    reverse_proxy 127.0.0.1:5174 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
    }
    header X-Frontend "frontend-ex"
}

# Ops routes
handle /health {
    reverse_proxy 127.0.0.1:5174 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
    }
    header X-Frontend "frontend-ex"
}

handle /stats {
    reverse_proxy 127.0.0.1:5174 {
