        header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
    }
    header X-Frontend "frontend-ex"
}

# Tx share assets: keep upstream Cache-Control (og-image is max-age=300 in app)
handle /tx/*/og-image.svg {
    reverse_proxy 127.0.0.1:5174 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
    }
    header X-Frontend "frontend-ex"
}

# Transaction pages
handle /tx/* {
