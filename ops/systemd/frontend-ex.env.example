# Copy alongside the app and adjust the path in the systemd unit's EnvironmentFile=.

PHX_SERVER=true
LISTEN_ADDR=127.0.0.1:5174
PHX_HOST=sepolia.53627.org
SECRET_KEY_BASE=REPLACE_ME

# Blockscout upstream
BLOCKSCOUT_API_URL=http://127.0.0.1:80
# Optional override for `/txs` upstream calls to `/api/v2/transactions` (pagination).
# BLOCKSCOUT_TXS_API_URL=https://eth-sepolia.blockscout.com
BLOCKSCOUT_URL=https://sepolia.53627.org

# frontend-ex runtime
FF_SKIN=classic
BASE_URL=https://sepolia.53627.org

# Monitoring (Prometheus exposition format on localhost)
FF_METRICS_ENABLED=true
FF_METRICS_PORT=9568
