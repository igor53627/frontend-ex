# Example of the deploy-time config `deploy.sh` sources.
# Copy to `.env.deploy` (gitignored) and fill in the values for your
# environment. `deploy.sh` sources `.env.deploy` on each invocation and
# explicit env vars (e.g. `FX_DEPLOY_SERVER=x ./deploy.sh`) override it.
#
# Required:
#   SESSION_SIGNING_SALT   — Phoenix session cookie signing salt
#   LIVE_VIEW_SIGNING_SALT — Phoenix LiveView session signing salt
#
# Both are *build-time* secrets — Phoenix session options are compile-time,
# so `mix release` needs them in the environment. Generate each with:
#
#   mix phx.gen.secret 32
#
# Store the generated values in `.env.deploy` and never commit them.

: "${FX_DEPLOY_SERVER:=your-server-alias-or-host}"
: "${FX_DEPLOY_PATH:=/path/on/remote/frontend-ex}"

# Required build-time secrets (see comment above).
# : "${SESSION_SIGNING_SALT:=paste-your-session-salt-here}"
# : "${LIVE_VIEW_SIGNING_SALT:=paste-your-liveview-salt-here}"
