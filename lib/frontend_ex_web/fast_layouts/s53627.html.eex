<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= @page_title || "Explorer" %></title>
    <link rel="icon" type="image/png" href="https://sepolia.53627.org/favicon/favicon-32x32.png">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/css/style1.css">
    <%= @head_meta || "" %>
    <%= @styles || "" %>
</head>
<body>
    <div class="layout">
        <aside class="sidebar" id="sidebar">
            <button class="sidebar-toggle" onclick="document.getElementById('sidebar').classList.toggle('expanded'); document.querySelector('.main-wrapper').style.marginLeft = document.getElementById('sidebar').classList.contains('expanded') ? '220px' : '80px';" title="Toggle sidebar">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <div class="sidebar-logo">
                <svg viewBox="0 0 36 36" fill="none">
                    <path d="M18 2L4 10v16l14 8 14-8V10L18 2z" fill="#0d6efd"/>
                    <path d="M18 6L8 12v12l10 6 10-6V12L18 6z" fill="white"/>
                    <path d="M18 10L12 14v8l6 4 6-4v-8l-6-4z" fill="#0d6efd"/>
                </svg>
            </div>
            <span class="testnet-badge">testnet</span>
            <nav class="sidebar-nav">
                <a href="/" class="sidebar-link active" title="Home">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    <span class="sidebar-link-text">Home</span>
                </a>
                <a href="<%= @explorer_url %>/blocks" class="sidebar-link" title="Blocks">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                    <span class="sidebar-link-text">Blocks</span>
                </a>
                <a href="<%= @explorer_url %>/txs" class="sidebar-link" title="Transactions">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                    <span class="sidebar-link-text">Transactions</span>
                </a>
                <a href="<%= @explorer_url %>/tokens" class="sidebar-link" title="Tokens">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <circle cx="12" cy="12" r="4"/>
                    </svg>
                    <span class="sidebar-link-text">Tokens</span>
                </a>
                <a href="<%= @explorer_url %>/api-docs" class="sidebar-link" title="API">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="16 18 22 12 16 6"/>
                        <polyline points="8 6 2 12 8 18"/>
                    </svg>
                    <span class="sidebar-link-text">API</span>
                </a>
            </nav>
            <div class="sidebar-bottom">
                <a href="<%= @explorer_url %>/settings" class="sidebar-link" title="Settings">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                    </svg>
                    <span class="sidebar-link-text">Settings</span>
                </a>
            </div>
        </aside>
        <div class="main-wrapper">
            <%= assigns[:topbar] || "" %>
            <main class="main-content"><%= @inner_content %></main>
        </div>
    </div>
    <%= @scripts || "" %>
    <script>
    document.querySelectorAll('.copy-btn[data-copy]').forEach(function(btn) {
        btn.addEventListener('click', function() {
            navigator.clipboard.writeText(this.dataset.copy).catch(function(err) {
                console.error('Copy failed:', err);
            });
        });
    });
    </script>
</body>
</html>
