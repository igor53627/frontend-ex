<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= @page_title || "Sepolia Testnet Explorer" %></title>
    <link rel="icon" type="image/png" href="https://sepolia.53627.org/favicon/favicon-32x32.png">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/css/style2.css">
    <link rel="stylesheet" href="/static/css/style2-overrides.css">
    <%= Phoenix.HTML.raw(@head_meta || "") %>
    <%= Phoenix.HTML.raw(@styles || "") %>
</head>
<body>
    <header class="header">
        <div class="topbar">
            <div class="container topbar-inner">
                <div class="topbar-left">
                    <span class="topbar-badge">Sepolia Testnet</span>
                </div>
                <div class="topbar-right">
                    <form class="topbar-search" action="/search" method="get">
                        <span class="topbar-search-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24">
                                <circle cx="11" cy="11" r="7"></circle>
                                <line x1="20" y1="20" x2="16.65" y2="16.65"></line>
                            </svg>
                        </span>
                        <input type="text" name="q" class="topbar-search-input" placeholder="Search by Address / Txn Hash / Block / Token" aria-label="Search by Address / Txn Hash / Block / Token">
                        <span class="topbar-search-shortcut" aria-hidden="true"><kbd>/</kbd></span>
                    </form>
                    <button class="topbar-icon-btn" type="button" aria-label="Knowledge Base" title="Knowledge Base">
                        <svg viewBox="0 0 24 24">
                            <path d="M4 5h6a3 3 0 0 1 3 3v11H7a3 3 0 0 0-3 3V5z"></path>
                            <path d="M20 5h-6a3 3 0 0 0-3 3v11h6a3 3 0 0 1 3 3V5z"></path>
                        </svg>
                    </button>
                    <button class="topbar-icon-btn" type="button" aria-label="Theme" title="Theme">
                        <svg viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="4"></circle>
                            <path d="M12 2v3"></path>
                            <path d="M12 19v3"></path>
                            <path d="M4.2 4.2l2.1 2.1"></path>
                            <path d="M17.7 17.7l2.1 2.1"></path>
                            <path d="M2 12h3"></path>
                            <path d="M19 12h3"></path>
                            <path d="M4.2 19.8l2.1-2.1"></path>
                            <path d="M17.7 6.3l2.1-2.1"></path>
                        </svg>
                    </button>
                    <button class="topbar-icon-btn" type="button" aria-label="Network" title="Network">
                        <svg viewBox="0 0 24 24">
                            <path d="M12 2l4.5 8-4.5 4.5L7.5 10 12 2z"></path>
                            <path d="M12 15l4.5-4.5-4.5 12-4.5-12L12 15z"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div class="header-main">
            <div class="container header-top">
                <a href="/" class="logo">
                    <svg class="logo-mark" viewBox="0 0 32 32" aria-hidden="true">
                        <circle cx="16" cy="16" r="16" fill="#1f2a44"></circle>
                        <rect x="8.5" y="9" width="4" height="14" fill="#ffffff"></rect>
                        <rect x="14" y="7" width="4" height="18" fill="#ffffff"></rect>
                        <rect x="19.5" y="11" width="4" height="12" fill="#ffffff"></rect>
                    </svg>
                    <span class="logo-title">Sepolia Explorer</span>
                </a>

                <nav class="nav" aria-label="Primary">
                    <a href="/" class="nav-link <%= assigns[:nav_home] || "" %>">Home</a>

                    <div class="nav-dropdown">
                        <button class="nav-link nav-dropdown-toggle <%= assigns[:nav_blocks] || "" %> <%= assigns[:nav_txs] || "" %>" type="button" aria-haspopup="true" aria-expanded="false">
                            Blockchain
                            <svg class="nav-caret" viewBox="0 0 12 12" aria-hidden="true">
                                <path d="M3 4.5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </button>
                        <div class="nav-menu">
                            <div class="nav-menu-inner">
                                <a href="/txs" class="nav-menu-item">Transactions</a>
                                <a href="/blocks" class="nav-menu-item">View Blocks</a>
                            </div>
                        </div>
                    </div>

                    <div class="nav-dropdown">
                        <button class="nav-link nav-dropdown-toggle <%= assigns[:nav_tokens] || "" %>" type="button" aria-haspopup="true" aria-expanded="false">
                            Tokens
                            <svg class="nav-caret" viewBox="0 0 12 12" aria-hidden="true">
                                <path d="M3 4.5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </button>
                        <div class="nav-menu">
                            <div class="nav-menu-inner">
                                <a href="/tokens" class="nav-menu-item">Tokens</a>
                            </div>
                        </div>
                    </div>

                    <div class="nav-dropdown">
                        <button class="nav-link nav-dropdown-toggle <%= assigns[:nav_nfts] || "" %>" type="button" aria-haspopup="true" aria-expanded="false">
                            NFTs
                            <svg class="nav-caret" viewBox="0 0 12 12" aria-hidden="true">
                                <path d="M3 4.5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </button>
                        <div class="nav-menu">
                            <div class="nav-menu-inner">
                                <a href="/nft-latest-mints" class="nav-menu-item">NFT Latest Mints</a>
                                <a href="/nft-transfers" class="nav-menu-item">NFT Transfers</a>
                            </div>
                        </div>
                    </div>

                    <div class="nav-dropdown">
                        <button class="nav-link nav-dropdown-toggle" type="button" aria-haspopup="true" aria-expanded="false">
                            More
                            <svg class="nav-caret" viewBox="0 0 12 12" aria-hidden="true">
                                <path d="M3 4.5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </button>
                        <div class="nav-menu nav-menu-right">
                            <div class="nav-menu-inner">
                                <a href="/api-docs" class="nav-menu-item">APIs</a>
                            </div>
                        </div>
                    </div>
                </nav>

                <span class="topbar-badge mobile-badge">Sepolia Testnet</span>

                <button class="mobile-menu-btn" type="button" aria-label="Open menu" title="Menu">
                    <svg viewBox="0 0 24 24">
                        <line x1="4" y1="7" x2="20" y2="7"></line>
                        <line x1="4" y1="12" x2="20" y2="12"></line>
                        <line x1="4" y1="17" x2="20" y2="17"></line>
                    </svg>
                </button>
            </div>
        </div>
    </header>

    <main class="main">
        <div class="container">
            <%= @inner_content %>
        </div>
    </main>

    <footer class="footer">
        <div class="container footer-inner">
            <div class="footer-left">
                <div class="footer-text">
                    Powered by <a href="https://ethereum.org">Ethereum</a>
                </div>
                <div class="footer-text">
                    Sepolia Testnet Explorer
                </div>
            </div>
            <div class="footer-links">
                <a href="/terms">Terms</a>
                <span class="footer-divider">|</span>
                <a href="/privacy">Privacy</a>
            </div>
        </div>
    </footer>

    <%= Phoenix.HTML.raw(@scripts || "") %>
    <script>
    document.querySelectorAll('.copy-btn[data-copy]').forEach(function(btn) {
        btn.addEventListener('click', function() {
            navigator.clipboard.writeText(this.dataset.copy).catch(function(err) {
                console.error('Copy failed:', err);
            });
        });
    });

    // Dropdown menu hover handling
    document.querySelectorAll('.nav-dropdown').forEach(function(dropdown) {
        var menu = dropdown.querySelector('.nav-menu-inner');
        var timeout;
        
        function showMenu() {
            clearTimeout(timeout);
            menu.classList.add('is-open');
        }
        
        function hideMenu(e) {
            var related = e.relatedTarget;
            if (related && dropdown.contains(related)) {
                return;
            }
            menu.classList.remove('is-open');
        }
        
        dropdown.addEventListener('mouseenter', showMenu);
        dropdown.addEventListener('mouseleave', hideMenu);
        
        var menuWrapper = dropdown.querySelector('.nav-menu');
        if (menuWrapper) {
            menuWrapper.addEventListener('mouseenter', showMenu);
        }
    });
    </script>
</body>
</html>
