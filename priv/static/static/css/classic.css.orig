:root {
  --bg: #f8f9fa;
  --bg-card: #ffffff;
  --border: #e9ecef;
  --text: #1e2022;
  --text-secondary: #6c757d;
  --text-muted: #8c98a4;
  --link: #0784c3;
  --link-hover: #066a9c;
  --success: #00a186;
  --success-bg: #00a18614;
  --danger: #dc3545;
  --warning: #f8b600;
  --warning-bg: #f8b60014;
  --primary: #3498db;
  --primary-bg: #3498db14;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: "Roboto", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.5;
  font-size: 14px;
}

a {
  color: var(--link);
  text-decoration: none;
}

a:hover {
  color: var(--link-hover);
}

/* Layout */
.container {
  width: 100%;
  max-width: 1140px;
  margin: 0 auto;
  padding: 0 16px;
}

.main {
  padding: 24px 0 40px;
}

/* Header */
.header {
  background: #ffffff;
  border-bottom: 1px solid var(--border);
}

.topbar {
  background: #ffffff;
  border-bottom: 1px solid var(--border);
  color: var(--text-secondary);
  font-size: 12px;
}

.topbar-inner {
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.topbar-left {
  display: flex;
  align-items: center;
  gap: 16px;
}

.topbar-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
}

.topbar-label {
  color: var(--text-secondary);
}

.topbar-value {
  color: var(--text);
  font-weight: 500;
}

.header-main {
  background: #ffffff;
}

.header-top {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 10px 0;
}

.logo {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: var(--text);
  font-size: 16px;
  font-weight: 700;
  text-decoration: none;
  line-height: 1;
  white-space: nowrap;
}

.logo:hover {
  color: var(--text);
}

.network-badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 8px;
  border-radius: 999px;
  background: #f8f9fa;
  border: 1px solid var(--border);
  font-size: 11px;
  font-weight: 500;
  color: var(--text-secondary);
}

.logo-title {
  font-size: 16px;
  font-weight: 700;
}

.global-search {
  flex: 1 1 auto;
  max-width: 520px;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: #f8f9fa;
}

.global-search:focus-within {
  background: #ffffff;
  border-color: #cbd3da;
  box-shadow: 0 0 0 3px rgba(7, 132, 195, 0.12);
}

.global-search-icon {
  width: 16px;
  height: 16px;
  color: var(--text-muted);
  flex-shrink: 0;
}

.global-search-input {
  width: 100%;
  border: none;
  outline: none;
  background: transparent;
  font-size: 13px;
  color: var(--text);
}

.global-search-input::placeholder {
  color: var(--text-muted);
}

.nav {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-left: auto;
}

.nav-link {
  display: inline-flex;
  align-items: center;
  padding: 8px 10px;
  border-radius: 8px;
  font-size: 13px;
  color: var(--text-secondary);
  text-decoration: none;
}

.nav-link:hover {
  color: var(--text);
  background: #f8f9fa;
}

.nav-link.active {
  color: var(--link);
  font-weight: 500;
}

@media (max-width: 1024px) {
  .header-top {
    flex-wrap: wrap;
  }

  .global-search {
    order: 3;
    max-width: none;
    flex: 1 1 100%;
  }

  .nav {
    order: 2;
    margin-left: 0;
  }
}

/* Cards */
.card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
}

.card-header {
  padding: 12px 20px;
  background: #f8f9fa;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
  font-weight: 500;
}

.card-body {
  padding: 20px;
}

/* Badge */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 8px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 500;
}

.badge-success {
  background: var(--success-bg);
  color: var(--success);
}

.badge-warning {
  background: var(--warning-bg);
  color: #b38600;
}

.badge-danger {
  background: #dc354514;
  color: var(--danger);
}

.badge-primary {
  background: var(--primary-bg);
  color: var(--primary);
}

.badge-secondary {
  background: #6c757d14;
  color: var(--text-secondary);
}

/* Hash/Mono */
.hash {
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
  font-size: 13px;
}

a.hash:hover {
  text-decoration: underline;
}

.hash--truncate {
  max-width: 160px;
  display: inline-block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hash--sm {
  max-width: 120px;
}

/* Table */
table {
  width: 100%;
  border-collapse: collapse;
}

th,
td {
  padding: 12px 16px;
  text-align: left;
  border-bottom: 1px solid var(--border);
  font-size: 14px;
}

th {
  color: var(--text-secondary);
  font-weight: 500;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

thead th {
  background: #f8f9fa;
}

tbody tr:hover {
  background: #f8f9fa;
}

/* Tabs */
.tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 16px 0;
}

.tab {
  display: inline-flex;
  align-items: center;
  padding: 7px 12px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: #f8f9fa;
  color: var(--text-secondary);
  font-size: 13px;
  font-weight: 500;
  text-decoration: none;
}

.tab:hover {
  background: #eef1f4;
  color: var(--text);
}

.tab.active {
  background: var(--link);
  border-color: var(--link);
  color: #ffffff;
}

/* Address summary */
.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16px;
  margin-bottom: 12px;
}

.summary-card {
  padding: 14px 16px;
}

.summary-title {
  font-size: 13px;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 10px;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  padding: 6px 0;
  border-top: 1px solid var(--border);
  font-size: 13px;
}

.summary-row:first-of-type {
  border-top: none;
}

.summary-label {
  color: var(--text-muted);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  white-space: nowrap;
}

.summary-value {
  color: var(--text);
  font-weight: 500;
  text-align: right;
  word-break: break-word;
}

.table-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  font-size: 13px;
}

.empty-state {
  padding: 24px 16px;
  text-align: center;
  color: var(--text-muted);
  font-size: 13px;
}

/* Notice */
.notice {
  margin: 12px 0;
  padding: 10px 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: #f8f9fa;
  font-size: 12px;
  color: var(--text-secondary);
}

.notice-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.notice-dot {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: rgba(7, 132, 195, 0.12);
  color: var(--link);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 12px;
  flex-shrink: 0;
}

.notice-close {
  border: none;
  background: transparent;
  color: var(--text-muted);
  font-size: 18px;
  line-height: 1;
  cursor: pointer;
  padding: 0 4px;
}

.notice-close:hover {
  color: var(--text);
}

.link {
  color: var(--link);
}

.link:hover {
  color: var(--link-hover);
}

@media (max-width: 980px) {
  .summary-grid {
    grid-template-columns: 1fr;
  }
}

/* Footer */
.footer {
  background: #ffffff;
  border-top: 1px solid var(--border);
  color: var(--text-secondary);
  padding: 28px 0;
  margin-top: 48px;
}

.footer-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
}

.footer-text {
  font-size: 13px;
}

.footer a {
  color: var(--link);
}

.footer a:hover {
  color: var(--link-hover);
}

/* Utilities */
.truncate {
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-muted {
  color: var(--text-muted);
}

.text-secondary {
  color: var(--text-secondary);
}

.fw-medium {
  font-weight: 500;
}

.fw-bold {
  font-weight: 700;
}

.text-uppercase {
  text-transform: uppercase;
}

/* Copy Button */
.copy-btn {
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  color: var(--text-muted);
  opacity: 0.7;
  vertical-align: middle;
}

.copy-btn:hover {
  opacity: 1;
  color: var(--link);
}

.copy-btn svg {
  width: 14px;
  height: 14px;
  fill: currentColor;
}

/* Testnet Banner */
.testnet-banner {
  background: none;
  border: none;
  color: var(--danger);
  padding: 0;
  font-size: 13px;
  margin: 0 0 16px;
}

.testnet-banner::before {
  content: "[";
  margin-right: 4px;
}

.testnet-banner::after {
  content: "]";
  margin-left: 4px;
}
